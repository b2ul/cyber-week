{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "unlock.html",
      "use": "@vercel/static"
    },
    {
      "src": "reset.html",
      "use": "@vercel/static"
    },
    {
      "src": "winner.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/winner",
      "dest": "/winner.js"
    },
    {
      "src": "/unlock.html",
      "dest": "/unlock.html"
    },
    {
      "src": "/reset.html",
      "dest": "/reset.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
